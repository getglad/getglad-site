---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import { postUrl } from '../utils/postUrl';
import headshot from '../assets/headshot.jpg';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, categories, series } = post.data;
const tag = categories[0]?.replace(/-/g, ' ');

// Series siblings → part N + next-in-series.
let seriesNav: {
  name: string;
  order: number;
  total: number;
  next: CollectionEntry<'blog'> | null;
} | null = null;

if (series) {
  const siblings = (
    await getCollection('blog', ({ data }) => data.series === series && !data.draft)
  ).sort((a, b) => (a.data.seriesOrder ?? 0) - (b.data.seriesOrder ?? 0));
  const i = siblings.findIndex((s) => s.id === post.id);
  seriesNav = {
    name: series,
    order: post.data.seriesOrder ?? i + 1,
    total: siblings.length,
    next: i >= 0 && i < siblings.length - 1 ? siblings[i + 1] : null,
  };
}
---

<BaseLayout title={title} description={description} type="article" publishedDate={pubDate}>
  <div class="container container--post post">
    <a href="/writing/" class="btn btn--link btn--sm post__back">← All posts</a>

    <article>
      {
        seriesNav && (
          <a href="/writing/" class="series-eyebrow">
            <span class="series-eyebrow__tag">series</span>
            <span class="series-eyebrow__label">
              Part {seriesNav.order} of {seriesNav.total} · {seriesNav.name}
            </span>
          </a>
        )
      }

      {tag && <span class="post__meta">{tag}</span>}

      <h1 class="post__title">{title}</h1>
      <p class="prose-p post__lead">{description}</p>
      <hr class="post__divider" />

      <div class="prose">
        <slot />
      </div>

      {
        seriesNav?.next && (
          <div class="series-next">
            <span class="label" style="display:block;margin-bottom:12px">
              Continue the series · {seriesNav.name}
            </span>
            <a class="series-next__row" href={postUrl(seriesNav.next.data)} rel="next">
              <span style="display:flex;flex-direction:column;gap:3px">
                <span class="small faint">Part {seriesNav.next.data.seriesOrder}</span>
                <span class="series-next__title">{seriesNav.next.data.title}</span>
              </span>
              <span class="series-next__arrow">→</span>
            </a>
          </div>
        )
      }

      <div class="post__author">
        <Image src={headshot} alt="" width={96} height={96} />
        <div style="display:flex;flex-direction:column;gap:2px">
          <span class="post__author-name">Matthew Gladney</span>
          <span class="small muted">Cloud security · agentic security research</span>
        </div>
      </div>
    </article>
  </div>
</BaseLayout>
