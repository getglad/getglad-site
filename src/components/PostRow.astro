---
import type { CollectionEntry } from 'astro:content';
import { postUrl } from '../utils/postUrl';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const url = postUrl(post.data);
const tag = post.data.categories[0]?.replace(/-/g, ' ');
---

<a class="post-row" href={url}>
  {tag && <span class="post-row__tag label">{tag}</span>}
  <h3 class="h3">{post.data.title}</h3>
  <p class="prose-p post-row__excerpt">{post.data.description}</p>
  <span class="post-row__more">Continue reading →</span>
</a>
