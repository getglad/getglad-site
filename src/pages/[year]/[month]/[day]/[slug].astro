---
import { getCollection, render } from 'astro:content';
import PostLayout from '../../../../layouts/PostLayout.astro';

// Legacy posts keep their original dated permalink /YYYY/MM/DD/slug/ so
// previously-indexed URLs and backlinks keep resolving.
export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.legacy);
  const pad = (n: number): string => String(n).padStart(2, '0');
  return posts.map((post) => {
    const d = post.data.pubDate;
    return {
      params: {
        year: String(d.getUTCFullYear()),
        month: pad(d.getUTCMonth() + 1),
        day: pad(d.getUTCDate()),
        slug: post.data.slug,
      },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<PostLayout post={post}>
  <Content />
</PostLayout>
