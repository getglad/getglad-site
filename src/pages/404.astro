---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not found" description="That page doesn’t exist.">
  <div class="container" style="padding-top:96px">
    <span class="label">404</span>
    <h1 class="display" style="margin:12px 0 16px">This page wandered off.</h1>
    <p class="body-lg" style="color:var(--fg-1);max-width:520px">
      Try the <a href="/">home page</a>, the <a href="/writing/">writing</a>, or the
      <a href="/projects/">projects</a>.
    </p>
  </div>
</BaseLayout>
